# --- Database (Neon) ---
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (single-user passcode) ---
# bcrypt hash of your passcode. Generate: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSCODE',10))"
PASSCODE_HASH=""
# 32+ char random secret for signing the session cookie (jose HS256)
SESSION_SECRET=""

# --- Vertex AI (Gemini) — reuse clinical-infra service account ---
GCP_PROJECT_ID="clinical-infra"
GCP_LOCATION="asia-northeast1"
# base64-encoded service-account JSON (set in Vercel, never committed)
GCP_SA_KEY_BASE64=""
GEMINI_MODEL_REASONING="gemini-2.5-pro"
GEMINI_MODEL_UTILITY="gemini-2.5-flash"

# --- Vercel Blob (artefact uploads) ---
BLOB_READ_WRITE_TOKEN=""
